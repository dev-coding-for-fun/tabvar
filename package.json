    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.9.0",
    "knip": "^6.8.0",
    "kysely-codegen": "^0.20.0",
    "miniflare": "^4.20260424.0",
    "node-fetch": "^3.3.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.6",
    "wrangler": "^4.85.0"
