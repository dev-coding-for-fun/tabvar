{
  "name": "tabvar",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "build:cloudflare": "npm run build && node ./scripts/apply-production-d1-migrations.mjs",
    "db:migrate:production": "wrangler d1 migrations apply DB --remote --env production",
    "deploy": "npm run build && wrangler pages deploy",
    "dev": "react-router dev",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "wrangler pages dev ./build/client",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typegen": "wrangler types && kysely-codegen --out-file app/lib/db.d.ts",
    "preview": "npm run build && wrangler pages dev",
    "cf-typegen": "wrangler types",
    "knip": "knip"
  },
  "dependencies": {
    "@alwaysmeticulous/recorder-loader": "^2.277.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@coji/remix-auth-google": "^4.2.0",
    "@google/generative-ai": "^0.24.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@mantine/core": "^9.1.0",
    "@mantine/dates": "^9.1.0",
    "@mantine/dropzone": "^9.1.0",
    "@mantine/hooks": "^9.1.0",
    "@mantine/notifications": "^9.1.0",
    "@mantine/tiptap": "^9.1.0",
    "@mapbox/togeojson": "^0.16.2",
    "@react-router/cloudflare": "^7.14.2",
    "@sentry/cloudflare": "^10.50.0",
    "@sentry/react-router": "^10.50.0",
    "@sentry/vite-plugin": "^5.2.0",
    "@tabler/icons-react": "^3.41.1",
    "@tiptap/extension-color": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "arctic": "^3.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "he": "^1.2.0",
    "isbot": "^5.1.39",
    "kysely": "^0.28.16",
    "kysely-d1": "^0.4.0",
    "mantine-datatable": "^8.3.13",
    "mapbox-gl": "^3.22.0",
    "nanoid": "^5.1.9",
    "postcss": "^8.5.12",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "remix-auth": "^4.2.0",
    "remix-auth-oauth2": "^3.4.1",
    "tiny-invariant": "^1.3.3",
    "yet-another-react-lightbox-lite": "^1.11.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@react-router/dev": "^7.14.2",
    "@react-router/fs-routes": "^7.14.2",
    "@react-router/node": "^7.14.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/he": "^1.2.3",
    "@types/node": "^25.6.0",
